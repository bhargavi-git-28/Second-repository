#include <stdio.h>

int main() {
    int num1, num2, sum; // Declare integer variables

    printf("Enter two integers: "); // Prompt the user for input
    scanf("%d %d", &num1, &num2); // Read and store the user input

    sum = num1 + num2; // Calculate the sum using the '+' operator

    printf("Sum: %d\n", sum); // Print the calculated sum to the console

    return 0; // Indicate successful program termination
}
